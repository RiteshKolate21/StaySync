<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StatSync</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f7f7f7;
        }

        .header {
            width: 90%;
            margin: 20px auto;

            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header h2 {
            margin: 0;
        }

        .btn {
            background-color: #e63946;
            color: white;
            padding: 8px 16px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 14px;
            font-weight: bold;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
            transition: background 0.2s ease;
        }

        .btn:hover {
            background-color: #d62839;
        }


        h3 {
            text-align: center;
            margin: 20px 0;
        }

        .container {
            width: 90%;
            margin: auto;

            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .sub-container {
            background-color: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .sub-container:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        }

        img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .card-content {
            padding: 10px 15px;
        }

        .card-title {
            font-size: 18px;
            font-weight: bold;
            margin: 5px 0;

        }

        a {
            text-decoration: none;
            color: black;
        }

        .card-desc {
            font-size: 14px;
            color: #555;
            margin: 5px 0;
        }

        .card-price {
            font-size: 16px;
            font-weight: bold;
            color: #e63946;
            margin-top: 8px;
        }

        .location {
            font: 14px;
            margin-top: 7px;
            color: #777;
        }
    </style>
</head>

<body>
    <div class="header">
        <h2>All Stays</h2>
        <form action="/listings/new" method="get">
            <button class="btn">Create</button>
        </form>
    </div>
    <div class="container">
        <% for (const item of alllistings){ %>
            <div class="sub-container">
                <img src="<%= item.image.url %>" alt="">

                <div class="card-content">
                    <div class="card-title">
                        <a href="/listings/<%=item._id%>">
                            <%= item.title %>
                        </a>
                    </div>
                    <div class="card-desc">
                        <%= item.description %>
                    </div>
                    <div class="card-price">₹ <%= item.price %>
                    </div>
                    <div class="location">
                        <%= item.location %>,<%= item.country %>
                    </div>
                </div>
            </div>
            <% } %>
    </div>
</body>

</html>